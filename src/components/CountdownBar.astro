<div class="countdown-bar" data-countdown-bar>
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67V7z"></path>
  </svg>
  <span>
    En liquidación | Termina en
    <span class="timer" data-countdown>00h 00m 00s</span>
  </span>
</div>

<script>
  function initCountdown() {
    const el = document.querySelector('[data-countdown]');
    if (!el) return;

    const end = Date.now() + 4 * 60 * 60 * 1000;

    const tick = () => {
      const diff = Math.max(0, end - Date.now());
      const h = Math.floor(diff / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      el.textContent = `${String(h).padStart(2, '0')}h ${String(m).padStart(2, '0')}m ${String(s).padStart(2, '0')}s`;
    };

    tick();
    setInterval(tick, 1000);
  }

  initCountdown();
  document.addEventListener('astro:page-load', initCountdown);
</script>
